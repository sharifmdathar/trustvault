{
  "functions": {
    "dist/server/entry.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/entry.mjs"
    }
  ],
  "build": {
    "env": {
      "ENABLE_VC_BUILD": "1"
    }
  }
}